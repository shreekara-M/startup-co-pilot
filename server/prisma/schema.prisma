// ─── Prisma Schema for Startup Co-Pilot ────────────────────────
//
// Database:  SQLite (local dev) — swap to PostgreSQL with one line
// Tables:    6
// Run:       npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── 1. USERS ──────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String // bcrypt hash — never returned in API
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  ideas   StartupIdea[]
  exports ExportHistory[]

  @@map("users")
}

// ─── 2. STARTUP IDEAS ──────────────────────────────────────────

model StartupIdea {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  pitch     String? // elevator pitch, optional
  status    String   @default("draft") // draft | active | archived
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  details    StartupDetails?
  milestones Milestone[]
  exports    ExportHistory[]

  @@map("startup_ideas")
}

// ─── 3. STARTUP DETAILS (1:1 with idea) ────────────────────────

model StartupDetails {
  id             String   @id @default(uuid())
  ideaId         String   @unique @map("idea_id")
  problem        String?
  solution       String?
  targetAudience String?  @map("target_audience")
  uniqueValue    String?  @map("unique_value")
  revenueModel   String?  @map("revenue_model")
  marketSize     String?  @map("market_size")
  competitors    String   @default("[]") // JSON string
  teamNeeds      String   @default("[]") @map("team_needs") // JSON string
  budget         Float? // estimated cost
  updatedAt      DateTime @updatedAt @map("updated_at")

  idea StartupIdea @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@map("startup_details")
}

// ─── 4. MILESTONES (roadmap phases) ────────────────────────────

model Milestone {
  id          String   @id @default(uuid())
  ideaId      String   @map("idea_id")
  title       String
  description String?
  phase       String   @default("mvp") // mvp | v1 | v2 | future
  sortOrder   Int      @default(0) @map("sort_order")
  status      String   @default("pending") // pending | in_progress | completed
  targetDate  String?  @map("target_date") // ISO date string
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  idea  StartupIdea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@map("milestones")
}

// ─── 5. TASKS (work items inside milestones) ───────────────────

model Task {
  id          String   @id @default(uuid())
  milestoneId String   @map("milestone_id")
  title       String
  status      String   @default("todo") // todo | in_progress | done
  priority    String   @default("medium") // low | medium | high
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  milestone Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

// ─── 6. EXPORT HISTORY (audit log) ─────────────────────────────

model ExportHistory {
  id        String   @id @default(uuid())
  ideaId    String   @map("idea_id")
  userId    String   @map("user_id")
  format    String   @default("pdf") // pdf (extensible later)
  createdAt DateTime @default(now()) @map("created_at")

  idea StartupIdea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("export_history")
}
