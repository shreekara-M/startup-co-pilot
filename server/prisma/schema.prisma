// ─── Prisma Schema for Startup Co-Pilot ────────────────────────
//
// Database:  MongoDB
// Tables:    6
// Run:       npx prisma db push

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── 1. USERS ──────────────────────────────────────────────────

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  ideas   StartupIdea[]
  exports ExportHistory[]

  @@map("users")
}

// ─── 2. STARTUP IDEAS ──────────────────────────────────────────

model StartupIdea {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @map("user_id") @db.ObjectId
  title     String
  pitch     String?
  status    String   @default("draft")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  details    StartupDetails?
  milestones Milestone[]
  exports    ExportHistory[]

  @@map("startup_ideas")
}

// ─── 3. STARTUP DETAILS (1:1 with idea) ────────────────────────

model StartupDetails {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  ideaId         String   @unique @map("idea_id") @db.ObjectId
  problem        String?
  solution       String?
  targetAudience String?  @map("target_audience")
  uniqueValue    String?  @map("unique_value")
  revenueModel   String?  @map("revenue_model")
  marketSize     String?  @map("market_size")
  competitors    String   @default("[]")
  teamNeeds      String   @default("[]") @map("team_needs")
  budget         Float?
  updatedAt      DateTime @updatedAt @map("updated_at")

  idea StartupIdea @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@map("startup_details")
}

// ─── 4. MILESTONES (roadmap phases) ────────────────────────────

model Milestone {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  ideaId      String   @map("idea_id") @db.ObjectId
  title       String
  description String?
  phase       String   @default("mvp")
  sortOrder   Int      @default(0) @map("sort_order")
  status      String   @default("pending")
  targetDate  String?  @map("target_date")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  idea  StartupIdea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@map("milestones")
}

// ─── 5. TASKS (work items inside milestones) ───────────────────

model Task {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  milestoneId String   @map("milestone_id") @db.ObjectId
  title       String
  status      String   @default("todo")
  priority    String   @default("medium")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  milestone Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

// ─── 6. EXPORT HISTORY (audit log) ─────────────────────────────

model ExportHistory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  ideaId    String   @map("idea_id") @db.ObjectId
  userId    String   @map("user_id") @db.ObjectId
  format    String   @default("pdf")
  createdAt DateTime @default(now()) @map("created_at")

  idea StartupIdea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("export_history")
}
